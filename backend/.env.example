# Copy this file to .env and fill in your values.

DJANGO_SECRET_KEY=replace-me-with-a-long-random-string
DJANGO_DEBUG=false
DJANGO_ALLOWED_HOSTS=api.example.com,localhost

# Leave DATABASE_URL unset to use SQLite (./data/db.sqlite3).
# DATABASE_URL=postgres://user:password@db:5432/portfolio

# Comma-separated list of origins allowed to call the API from a browser
CORS_ALLOWED_ORIGINS=https://portfolio.example.com,http://localhost:5173
CSRF_TRUSTED_ORIGINS=https://portfolio.example.com

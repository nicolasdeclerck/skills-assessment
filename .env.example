# Copy this file to `.env` and fill in the values before running docker compose.

# Domains served by Traefik
DOMAIN_WEB=portfolio.example.com
DOMAIN_API=api.portfolio.example.com

# Django
DJANGO_SECRET_KEY=replace-me-with-a-long-random-string

# Traefik integration
TRAEFIK_NETWORK=traefik
TRAEFIK_CERT_RESOLVER=letsencrypt

# Uncomment if you switch to Postgres (and uncomment the db service
# in docker-compose.yml)
# POSTGRES_PASSWORD=change-me
# DATABASE_URL=postgres://portfolio:change-me@db:5432/portfolio
